{
    "name": "jeffersongoncalves/laravel-erp",
    "description": "Umbrella meta-package bundling the full Laravel ERP domain ecosystem (core, accounting, stock, selling, buying, manufacturing, assets, subcontracting, CRM, projects, support, quality, maintenance, HR).",
    "keywords": [
        "laravel",
        "erp",
        "umbrella",
        "bundle"
    ],
    "homepage": "https://github.com/jeffersongoncalves/laravel-erp",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Jefferson Gonçalves",
            "email": "gerson.simao.92@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "jeffersongoncalves/laravel-erp-core": "self.version",
        "jeffersongoncalves/laravel-erp-accounting": "self.version",
        "jeffersongoncalves/laravel-erp-stock": "self.version",
        "jeffersongoncalves/laravel-erp-selling": "self.version",
        "jeffersongoncalves/laravel-erp-buying": "self.version",
        "jeffersongoncalves/laravel-erp-manufacturing": "self.version",
        "jeffersongoncalves/laravel-erp-assets": "self.version",
        "jeffersongoncalves/laravel-erp-subcontracting": "self.version",
        "jeffersongoncalves/laravel-erp-crm": "self.version",
        "jeffersongoncalves/laravel-erp-projects": "self.version",
        "jeffersongoncalves/laravel-erp-support": "self.version",
        "jeffersongoncalves/laravel-erp-quality": "self.version",
        "jeffersongoncalves/laravel-erp-maintenance": "self.version",
        "jeffersongoncalves/laravel-erp-hr": "self.version"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "JeffersonGoncalves\\Erp\\Suite\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\Erp\\Suite\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JeffersonGoncalves\\Erp\\Suite\\ErpServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/jeffersongoncalves/laravel-erp/issues",
        "source": "https://github.com/jeffersongoncalves/laravel-erp"
    }
}
